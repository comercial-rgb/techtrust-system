# Optional overrides for in-app store links (Rate App). If unset, values come from
# `app.json` → `expo.extra.storeIosItmsUrl`, `storeIosWebUrl`, `storeAndroidUrl`.
# Replace iOS placeholder id in app.json before release.
EXPO_PUBLIC_IOS_APP_STORE_URL=
EXPO_PUBLIC_IOS_APP_STORE_WEB_URL=
EXPO_PUBLIC_ANDROID_PLAY_STORE_URL=
